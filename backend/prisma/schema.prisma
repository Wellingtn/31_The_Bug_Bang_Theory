generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Provider {
  LOCAL
  GOOGLE
  GITHUB
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String?
  provider  Provider @default(LOCAL)
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
